polkit.addRule(function(action, subject) {
    if (action.id.startsWith("org.freedesktop.NetworkManager")) {
        return polkit.Result.YES;
    }
});

polkit.addRule(function(action, subject) {
    if (action.id.startsWith("org.feralinteractive.GameMode.") &&
        subject.isInGroup("gamemode")) {
        return polkit.Result.YES;
    }
});
